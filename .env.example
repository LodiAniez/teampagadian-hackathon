# Copy to .env and fill in. Same file feeds apps/api (server) and apps/web (NEXT_PUBLIC_* vars).

# ---- Database (Supabase Postgres) ----
DATABASE_URL="postgresql://postgres:[password]@localhost:5432/raket?schema=public"
DIRECT_URL="postgresql://postgres:[password]@localhost:5432/raket?schema=public"

# ---- Supabase ----
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ---- Stripe (test mode) ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ---- Anthropic ----
ANTHROPIC_API_KEY="sk-ant-..."

# ---- Resend ----
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="invoices@yourdomain.com"

# ---- JWT ----
JWT_SECRET="change-me-to-a-random-32-plus-char-secret-string"

# ---- API / Web ----
PORT=3001
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Exchange rate ----
EXCHANGE_RATE_API_URL="https://api.exchangerate.host"

CORS_ORIGINS="http://localhost:3000"
