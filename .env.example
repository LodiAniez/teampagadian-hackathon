# Copy to .env and fill in. Same file feeds apps/api (server) and apps/web (NEXT_PUBLIC_* vars).

# ---- Database (Supabase Postgres) ----
DATABASE_URL="postgresql://postgres:[password]@localhost:5432/raket?schema=public"
DIRECT_URL="postgresql://postgres:[password]@localhost:5432/raket?schema=public"
LOCAL_DATABASE_URL="postgresql://pguser:pgpassword@localhost:5432/postgres"
LOCAL_DIRECT_URL="postgresql://pguser:pgpassword@localhost:5432/postgres"

# ---- Supabase ----
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ---- Stripe (test mode) ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ---- Gemini (LLM for invoice parsing) ----
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.5-flash"

# ---- Resend ----
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="invoices@yourdomain.com"

# ---- JWT ----
JWT_SECRET="change-me-to-a-random-32-plus-char-secret-string"

# ---- API / Web ----
PORT=3001
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Exchange rate ----
EXCHANGE_RATE_API_URL="https://api.exchangerate.host"

CORS_ORIGINS="http://localhost:3000"

# ---- Expo (Mobile) ----
# Host only — the /api/v1 prefix is added by the ts-rest contract (packages/contracts).
# For Expo Go on a phone, replace localhost with your dev machine's LAN IP (e.g. 192.168.1.x).
EXPO_PUBLIC_API_URL="http://localhost:3001"
# Public web app base URL. Used to build invoice share URLs (`${APP_URL}/pay/{id}`)
# rendered into the QR code and Copy-link actions on the invoice success screen.
EXPO_PUBLIC_APP_URL="http://localhost:3000"
EXPO_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY=""
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Dev-only Bearer token for calling the authed API before login (TEA-17/18) ships.
# Paste a JWT from Supabase dashboard → Authentication → Users → pick a user → access_token.
# Remove once lib/auth.ts reads from expo-secure-store.
EXPO_PUBLIC_DEV_BEARER=""
# Dev-only: set to "true" to skip the Supabase-session redirect in the (authed) layout
# so screens can be tested in Expo Go without a real login. Ignored in production builds.
# Pair with EXPO_PUBLIC_DEV_BEARER above so API calls still authenticate.
EXPO_PUBLIC_DEV_BYPASS_AUTH=""
