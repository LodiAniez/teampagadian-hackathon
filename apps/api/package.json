    "@prisma/client": "^7.8.0",
    "@raket/contracts": "*",
    "@supabase/supabase-js": "^2.47.10",
    "@ts-rest/core": "^3.51.0",
    "@ts-rest/nest": "^3.51.0",
    "express": "^4.21.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.6",
