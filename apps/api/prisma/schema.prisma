// Raket database schema.
// Conventions: see docs/api-convention.md §5.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth & users
// ---------------------------------------------------------------------------

enum BirElection {
  EIGHT_PERCENT @map("8_percent")
  GRADUATED     @map("graduated")

  @@map("bir_election")
}

model User {
  id                String       @id @default(uuid()) @db.Uuid
  supabaseUserId    String?      @unique @map("supabase_user_id") @db.Uuid
  phone             String       @unique
  name              String?
  businessName      String?      @map("business_name")
  defaultCurrency   String       @default("USD") @map("default_currency") @db.VarChar(3)
  defaultHourlyRate Json?        @map("default_hourly_rate")
  bir2303Election   BirElection? @map("bir_2303_election")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  payoutMethods PayoutMethod[]
  clients       Client[]
  invoices      Invoice[]
  payments      Payment[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// Payout methods
// ---------------------------------------------------------------------------

enum PayoutMethodType {
  CARD         @map("card")
  GCASH        @map("gcash")
  MAYA         @map("maya")
  BANK_ACCOUNT @map("bank_account")

  @@map("payout_method_type")
}

model PayoutMethod {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      PayoutMethodType
  details   Json
  isDefault Boolean          @default(false) @map("is_default")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payouts Payout[]

  @@index([userId])
  @@map("payout_methods")
}

// ---------------------------------------------------------------------------
// Clients
// ---------------------------------------------------------------------------

model Client {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String
  email           String?
  country         String?  @db.VarChar(2) // ISO-3166 alpha-2
  defaultCurrency String   @default("USD") @map("default_currency") @db.VarChar(3)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([userId])
  @@map("clients")
}

// ---------------------------------------------------------------------------
// Invoices
// ---------------------------------------------------------------------------

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  void

  @@map("invoice_status")
}

enum InvoiceSourceType {
  text
  upload
  manual

  @@map("invoice_source_type")
}

model Invoice {
  id                      String            @id @default(uuid()) @db.Uuid
  userId                  String            @map("user_id") @db.Uuid
  clientId                String            @map("client_id") @db.Uuid
  number                  String
  status                  InvoiceStatus     @default(draft)
  amount                  Decimal           @db.Decimal(18, 2)
  currency                String            @db.VarChar(3)
  issueDate               DateTime          @map("issue_date") @db.Date
  dueDate                 DateTime          @map("due_date") @db.Date
  sourceType              InvoiceSourceType @map("source_type")
  sourceFileUrl           String?           @map("source_file_url")
  stripePaymentIntentId   String?           @unique @map("stripe_payment_intent_id")
  stripeCheckoutSessionId String?           @unique @map("stripe_checkout_session_id")
  stripeCheckoutUrl       String?           @map("stripe_checkout_url")
  publicShareToken        String?           @unique @map("public_share_token")
  qrCodeDataUrl           String?           @map("qr_code_data_url")
  sentAt                  DateTime?         @map("sent_at")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@unique([userId, number])
  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(uuid()) @db.Uuid
  invoiceId   String  @map("invoice_id") @db.Uuid
  description String
  quantity    Decimal @db.Decimal(18, 4)
  unit        String  @default("unit") @db.VarChar(32)
  rate        Decimal @db.Decimal(18, 2)
  amount      Decimal @db.Decimal(18, 2)
  position    Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

// ---------------------------------------------------------------------------
// Payments & payouts (settlement)
// ---------------------------------------------------------------------------

// Settlement state machine. The `PENDING` → `SETTLING` distinction is
// load-bearing: the TEA-76 retry sweep queries `SETTLING` to find on-chain
// transfers that need resubmission, and a newly-inserted Payment row (no
// viem call yet) must NOT match that filter or the sweep would double-submit
// every fresh payment. Transitions:
//   PENDING   — Payment row written by the webhook; on-chain leg not started
//   SETTLING  — `writeContract` submitted, waiting on `waitForTransactionReceipt`
//   SETTLED   — receipt confirmed; `morphTxHash` populated
//   FAILED    — retries exhausted; ops escalation required
enum MorphTxStatus {
  PENDING  @map("pending")
  SETTLING @map("settling")
  SETTLED  @map("settled")
  FAILED   @map("failed")

  @@map("morph_tx_status")
}

enum PayoutStatus {
  PENDING    @map("pending")
  PROCESSING @map("processing")
  DELIVERED  @map("delivered")
  FAILED     @map("failed")

  @@map("payout_status")
}

model Payment {
  id                     String        @id @default(uuid()) @db.Uuid
  invoiceId              String        @map("invoice_id") @db.Uuid
  userId                 String        @map("user_id") @db.Uuid
  // Set at webhook time when the Stripe PaymentIntent succeeds. Distinct from
  // Invoice.stripePaymentIntentId, which is set at checkout-session creation:
  // same PI ID, different lifecycle stage. The webhook handler resolves the
  // invoice by joining on this column.
  stripePaymentIntentId  String        @unique @map("stripe_payment_intent_id")
  // Not unique: a PaymentIntent can produce multiple charge IDs across retries
  // (e.g. 3DS fallback). stripePaymentIntentId is the idempotency key — see
  // TEA-76. Informational only; never the dedup target.
  stripeChargeId         String?       @map("stripe_charge_id")
  amountReceived         Decimal       @map("amount_received") @db.Decimal(14, 2)
  amountReceivedCurrency String        @map("amount_received_currency") @db.VarChar(3)
  amountPhp              Decimal       @map("amount_php") @db.Decimal(14, 2)
  fxRate                 Decimal       @map("fx_rate") @db.Decimal(12, 6)
  fxFeeAmount            Decimal       @map("fx_fee_amount") @db.Decimal(14, 2)
  // Stored as a DECIMAL FRACTION, NOT a percentage:
  //   1% fee → 0.0100   |   3% fee → 0.0300   |   100% fee → 1.0000
  // Decimal(5,4) = max 9.9999 as a number (= 999.99% in fraction terms),
  // well beyond any meaningful fee. The DB CHECK in the migration narrows
  // the domain to [0, 1] so a misconfigured app value can't slip in.
  // DO NOT store the percentage value (e.g. 8.0 for 8%) — that will fail
  // the CHECK and crash the webhook into Stripe's retry loop.
  fxFeePercent           Decimal       @map("fx_fee_percent") @db.Decimal(5, 4)
  stripeFeeAmount        Decimal?      @map("stripe_fee_amount") @db.Decimal(14, 2)
  morphTxHash            String?       @unique @map("morph_tx_hash")
  morphTxStatus          MorphTxStatus @default(PENDING) @map("morph_tx_status")
  // Incremented at each PENDING→SETTLING transition (i.e. each viem attempt
  // for this PI). SettlementService bails to FAILED past MAX_RETRIES so a
  // persistent RPC outage stops looping eventually instead of riding Stripe's
  // 3-day webhook redelivery window forever.
  morphRetryCount        Int           @default(0) @map("morph_retry_count")
  // Block number captured at Phase A via publicClient.getBlockNumber(). Used
  // as the `fromBlock` for the SettlementService balance-precheck on retries
  // — narrows the Transfer-event scan to a small window instead of genesis.
  // Nullable for forward-compatibility (rows that predate this feature have
  // no anchor; precheck falls back to a wide fixed-window scan in that case).
  morphAnchorBlock       BigInt?       @map("morph_anchor_block")
  paidAt                 DateTime      @map("paid_at")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  payout  Payout?

  // Access patterns:
  //   - (userId, paidAt DESC) — dashboard "recent payments".
  //   - morphTxStatus — settlement retry/recovery sweep (TEA-76).
  //   - invoiceId — single-invoice payment lookup + ON DELETE RESTRICT check
  //     against Invoice. The composite above can't serve this (Postgres
  //     can't use a composite index when the leading column is absent).
  @@index([userId, paidAt(sort: Desc)])
  @@index([morphTxStatus])
  @@index([invoiceId])
  @@map("payments")
}

model Payout {
  id             String       @id @default(uuid()) @db.Uuid
  paymentId      String       @unique @map("payment_id") @db.Uuid
  payoutMethodId String       @map("payout_method_id") @db.Uuid
  amountPhp      Decimal      @map("amount_php") @db.Decimal(14, 2)
  status         PayoutStatus @default(PENDING)
  externalTxnId  String?      @map("external_txn_id")
  completedAt    DateTime?    @map("completed_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  payment      Payment      @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  payoutMethod PayoutMethod @relation(fields: [payoutMethodId], references: [id], onDelete: Restrict)

  // Access patterns:
  //   - status — ops queries ("which payouts are stuck PROCESSING").
  //   - payoutMethodId — list payouts for a method + ON DELETE RESTRICT check
  //     against PayoutMethod. paymentId is unique-indexed via @unique above.
  @@index([status])
  @@index([payoutMethodId])
  @@map("payouts")
}
