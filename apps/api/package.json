{
  "name": "@raket/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/main.ts",
    "start:prod": "tsx src/main.ts",
    "lint": "echo \"(no lint configured)\"",
